datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id          String           @id @default(uuid())
  email       String           @unique
  name        String
  password    String
  phone       String?          // Captured during registration or enrollment confirmation
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  enrollments Enrollment[]
  progress    CourseProgress[]
}

model Enrollment {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId  String
  createdAt DateTime @default(now())

  @@unique([userId, courseId])
}

model CourseProgress {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId       String
  completedWeeks String[] // e.g. ["w0", "w1"]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, courseId])
}
